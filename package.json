{
  "name": "@djengo/app-helpers",
  "version": "1.0.0",
  "description": "Helper utilities and enums for Djengo proto contracts.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "files": [
    "dist/",
    "*.ts"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "author": "DJENGO Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AI-ZeeK/djengo-app-helpers.git"
  },
  "keywords": [
    "djengo",
    "app",
    "helpers",
    "enums",
    "utilities"
  ],
  "devDependencies": {
    "@types/node": "^20.11.19",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
}
